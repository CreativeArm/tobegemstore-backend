# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:3000,http://localhost:5173,https://tobegemstore.vercel.app

# MongoDB
MONGODB_URI=mongodb://localhost:27017/tobegemstore

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Email (Nodemailer - Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@tobegemstore.com

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Paystack (https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# PayPal — uses @paypal/paypal-server-sdk (handled client-side via React SDK)
# Get credentials at https://developer.paypal.com/dashboard
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
